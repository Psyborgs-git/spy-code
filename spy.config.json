{
  "version": 1,
  "db_path": ".spy-code/graph.db",
  "languages": {
    "rust": {
      "enabled": true,
      "roots": [
        "./"
      ],
      "ignore": [],
      "resolver": "builtin",
      "tsconfig": null
    },
    "python": {
      "enabled": true,
      "roots": [
        "./"
      ],
      "ignore": [],
      "resolver": "builtin",
      "tsconfig": null
    },
    "typescript": {
      "enabled": true,
      "roots": [
        "./"
      ],
      "ignore": [],
      "resolver": "builtin",
      "tsconfig": null
    },
    "go": {
      "enabled": true,
      "roots": [
        "./"
      ],
      "ignore": [],
      "resolver": "builtin",
      "tsconfig": null
    }
  },
  "git": {
    "enabled": true,
    "track_renames": true,
    "follow_symlinks": false
  },
  "indexing": {
    "max_file_size_kb": 2048,
    "parallelism": "auto",
    "fail_fast": false
  },
  "search": {
    "fts_tokenizer": "unicode61"
  }
}